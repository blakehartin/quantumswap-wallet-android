<?xml version="1.0" encoding="utf-8"?>

<!--
    Liquidity screen (ported from the desktop app's Liquidity page):
    the owner's LP positions (with per-row Remove), and an
    Add-Liquidity form. Position rows are built dynamically by
    LiquidityFragment into layout_liquidity_positions.
-->
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:id="@+id/top_linear_layout_liquidity_id"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:background="@android:color/transparent">
                <ImageButton
                    android:id="@+id/imageButton_liquidity_back_arrow"
                    android:layout_width="55dp"
                    android:layout_height="55dp"
                    android:padding="5dp"
                    android:scaleType="fitCenter"
                    android:layout_gravity="left"
                    android:background="@drawable/image_selector"
                    android:src="@drawable/arrow_back_circle_outline"
                    app:tint="@color/colorCommon6"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_centerHorizontal="true"
                android:layout_marginLeft="10dp"
                android:layout_marginRight="10dp"
                android:layout_below="@+id/top_linear_layout_liquidity_id"
                android:background="@drawable/center_container">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="15dp"
                    android:layout_marginLeft="10dp"
                    android:layout_marginRight="10dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/textView_liquidity_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingBottom="5dp"
                        android:gravity="center"
                        android:textSize="20dp"
                        android:textStyle="bold"
                        android:textColor="@color/colorCommon6" />

                    <View
                        android:layout_width="wrap_content"
                        android:layout_height="1dp"
                        android:layout_marginBottom="10dp"
                        android:alpha="0.2"
                        android:background="@drawable/line_2_shape" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/textView_liquidity_positions_title"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textSize="16dp"
                            android:textStyle="bold"
                            android:textColor="@color/colorCommon1" />

                        <ImageButton
                            android:id="@+id/imageButton_liquidity_refresh"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:padding="5dp"
                            android:scaleType="fitCenter"
                            android:background="@drawable/image_selector"
                            android:src="@drawable/retry"
                            app:tint="@color/colorCommon6" />

                        <ProgressBar
                            android:id="@+id/progress_liquidity"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:padding="5dp"
                            android:indeterminate="true"
                            android:indeterminateDrawable="@drawable/progress"
                            android:visibility="gone" />

                    </LinearLayout>

                    <TextView
                        android:id="@+id/textView_liquidity_no_positions"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingTop="10dp"
                        android:paddingBottom="10dp"
                        android:textSize="13dp"
                        android:textColor="@color/colorMutedSecondaryText" />

                    <LinearLayout
                        android:id="@+id/layout_liquidity_positions"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />

                    <View
                        android:layout_width="wrap_content"
                        android:layout_height="1dp"
                        android:layout_marginTop="15dp"
                        android:layout_marginBottom="10dp"
                        android:alpha="0.2"
                        android:background="@drawable/line_2_shape" />

                    <TextView
                        android:id="@+id/textView_liquidity_add_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="16dp"
                        android:textStyle="bold"
                        android:textColor="@color/colorCommon1" />

                    <TextView
                        android:id="@+id/textView_liquidity_tokenA_label"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textSize="14dp"
                        android:textColor="@color/colorCommon3" />

                    <Spinner
                        android:id="@+id/spinner_liquidity_tokenA"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:background="@drawable/spinner_dropdown_background"
                        android:padding="10dp" />

                    <EditText
                        android:id="@+id/editText_liquidity_tokenA_custom"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:hint="0x..."
                        android:inputType="textNoSuggestions"
                        android:maxLength="66"
                        android:textSize="13dp"
                        android:textColor="@color/colorCommon6"
                        android:textColorHint="@color/colorMutedSecondaryText"
                        android:background="@drawable/text_input_selector"
                        android:visibility="gone" />

                    <EditText
                        android:id="@+id/editText_liquidity_amountA"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:inputType="numberDecimal"
                        android:maxLength="40"
                        android:textSize="15dp"
                        android:textColor="@color/colorCommon6"
                        android:textColorHint="@color/colorMutedSecondaryText"
                        android:background="@drawable/text_input_selector" />

                    <TextView
                        android:id="@+id/textView_liquidity_tokenB_label"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:textSize="14dp"
                        android:textColor="@color/colorCommon3" />

                    <Spinner
                        android:id="@+id/spinner_liquidity_tokenB"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:background="@drawable/spinner_dropdown_background"
                        android:padding="10dp" />

                    <EditText
                        android:id="@+id/editText_liquidity_tokenB_custom"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:hint="0x..."
                        android:inputType="textNoSuggestions"
                        android:maxLength="66"
                        android:textSize="13dp"
                        android:textColor="@color/colorCommon6"
                        android:textColorHint="@color/colorMutedSecondaryText"
                        android:background="@drawable/text_input_selector"
                        android:visibility="gone" />

                    <EditText
                        android:id="@+id/editText_liquidity_amountB"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:inputType="numberDecimal"
                        android:maxLength="40"
                        android:textSize="15dp"
                        android:textColor="@color/colorCommon6"
                        android:textColorHint="@color/colorMutedSecondaryText"
                        android:background="@drawable/text_input_selector" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/textView_liquidity_slippage_label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="14dp"
                            android:textColor="@color/colorCommon3" />

                        <EditText
                            android:id="@+id/editText_liquidity_slippage"
                            android:layout_width="80dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:inputType="numberDecimal"
                            android:maxLength="6"
                            android:text="1"
                            android:gravity="center"
                            android:textSize="14dp"
                            android:textColor="@color/colorCommon6"
                            android:background="@drawable/text_input_selector" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:textSize="14dp"
                            android:textColor="@color/colorCommon3"
                            android:text="%" />

                    </LinearLayout>

                    <TextView
                        android:id="@+id/textView_liquidity_status"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:textSize="13dp"
                        android:textColor="@color/quantumAmber"
                        android:visibility="gone" />

                    <Button
                        android:id="@+id/button_liquidity_add"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="14dp"
                        android:paddingLeft="20dp"
                        android:paddingRight="20dp"
                        android:paddingTop="6dp"
                        android:paddingBottom="6dp"
                        android:textAllCaps="false"
                        android:textColor="@color/colorWhite"
                        android:background="@drawable/button_green_selector" />

                </LinearLayout>

            </LinearLayout>

        </RelativeLayout>

    </ScrollView>

</RelativeLayout>
