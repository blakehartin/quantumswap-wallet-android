<?xml version="1.0" encoding="utf-8"?>

<!--
    Swap screen (ported from the desktop app's Swap page). Token
    pickers mirror the Send screen's asset spinner; a "Custom..."
    entry reveals a contract-address field. Quote/route/slippage and
    the approve+swap flow are driven by SwapFragment through the JS
    bridge DEX methods.
-->
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:id="@+id/top_linear_layout_swap_id"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:background="@android:color/transparent">
                <ImageButton
                    android:id="@+id/imageButton_swap_back_arrow"
                    android:layout_width="55dp"
                    android:layout_height="55dp"
                    android:padding="5dp"
                    android:scaleType="fitCenter"
                    android:layout_gravity="left"
                    android:background="@drawable/image_selector"
                    android:src="@drawable/arrow_back_circle_outline"
                    app:tint="@color/colorCommon6"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_centerHorizontal="true"
                android:layout_marginLeft="10dp"
                android:layout_marginRight="10dp"
                android:layout_below="@+id/top_linear_layout_swap_id"
                android:background="@drawable/center_container">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="15dp"
                    android:layout_marginLeft="10dp"
                    android:layout_marginRight="10dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/textView_swap_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingBottom="5dp"
                        android:gravity="center"
                        android:textSize="20dp"
                        android:textStyle="bold"
                        android:textColor="@color/colorCommon6" />

                    <View
                        android:layout_width="wrap_content"
                        android:layout_height="1dp"
                        android:layout_marginBottom="10dp"
                        android:alpha="0.2"
                        android:background="@drawable/line_2_shape" />

                    <TextView
                        android:id="@+id/textView_swap_release_banner"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="12dp"
                        android:textColor="@color/quantumAmber"
                        android:paddingBottom="8dp"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/textView_swap_from_label"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="14dp"
                        android:textStyle="bold"
                        android:textColor="@color/colorCommon1" />

                    <Spinner
                        android:id="@+id/spinner_swap_from"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:background="@drawable/spinner_dropdown_background"
                        android:padding="10dp" />

                    <EditText
                        android:id="@+id/editText_swap_from_custom"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:hint="0x..."
                        android:inputType="textNoSuggestions"
                        android:maxLength="66"
                        android:textSize="13dp"
                        android:textColor="@color/colorCommon6"
                        android:textColorHint="@color/colorMutedSecondaryText"
                        android:background="@drawable/text_input_selector"
                        android:visibility="gone" />

                    <EditText
                        android:id="@+id/editText_swap_amount_in"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:inputType="numberDecimal"
                        android:maxLength="40"
                        android:textSize="16dp"
                        android:textColor="@color/colorCommon6"
                        android:textColorHint="@color/colorMutedSecondaryText"
                        android:background="@drawable/text_input_selector" />

                    <TextView
                        android:id="@+id/textView_swap_to_label"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:textSize="14dp"
                        android:textStyle="bold"
                        android:textColor="@color/colorCommon1" />

                    <Spinner
                        android:id="@+id/spinner_swap_to"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:background="@drawable/spinner_dropdown_background"
                        android:padding="10dp" />

                    <EditText
                        android:id="@+id/editText_swap_to_custom"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:hint="0x..."
                        android:inputType="textNoSuggestions"
                        android:maxLength="66"
                        android:textSize="13dp"
                        android:textColor="@color/colorCommon6"
                        android:textColorHint="@color/colorMutedSecondaryText"
                        android:background="@drawable/text_input_selector"
                        android:visibility="gone" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/textView_swap_amount_out_label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="14dp"
                            android:textColor="@color/colorCommon3" />

                        <TextView
                            android:id="@+id/textView_swap_amount_out"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:textSize="16dp"
                            android:textStyle="bold"
                            android:textColor="@color/quantumCyan"
                            android:text="-" />

                    </LinearLayout>

                    <TextView
                        android:id="@+id/textView_swap_route"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textSize="12dp"
                        android:textColor="@color/colorMutedSecondaryText"
                        android:visibility="gone" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/textView_swap_slippage_label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="14dp"
                            android:textColor="@color/colorCommon3" />

                        <EditText
                            android:id="@+id/editText_swap_slippage"
                            android:layout_width="80dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:inputType="numberDecimal"
                            android:maxLength="6"
                            android:text="1"
                            android:gravity="center"
                            android:textSize="14dp"
                            android:textColor="@color/colorCommon6"
                            android:background="@drawable/text_input_selector" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:textSize="14dp"
                            android:textColor="@color/colorCommon3"
                            android:text="%" />

                    </LinearLayout>

                    <TextView
                        android:id="@+id/textView_swap_status"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:textSize="13dp"
                        android:textColor="@color/quantumAmber"
                        android:visibility="gone" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/button_swap_quote"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_margin="4dp"
                            android:paddingLeft="20dp"
                            android:paddingRight="20dp"
                            android:paddingTop="6dp"
                            android:paddingBottom="6dp"
                            android:textAllCaps="false"
                            android:textColor="@color/colorWhite"
                            android:background="@drawable/button_green_selector" />

                        <Button
                            android:id="@+id/button_swap_execute"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_margin="4dp"
                            android:paddingLeft="20dp"
                            android:paddingRight="20dp"
                            android:paddingTop="6dp"
                            android:paddingBottom="6dp"
                            android:textAllCaps="false"
                            android:textColor="@color/colorWhite"
                            android:background="@drawable/button_green_selector" />

                        <ProgressBar
                            android:id="@+id/progress_swap"
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:layout_margin="4dp"
                            android:indeterminate="true"
                            android:indeterminateDrawable="@drawable/progress"
                            android:visibility="gone" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </RelativeLayout>

    </ScrollView>

</RelativeLayout>
