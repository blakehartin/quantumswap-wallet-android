<?xml version="1.0" encoding="utf-8"?>

<!--
    QuantumSwap "Quantum Violet" palette — single DARK theme.

    Values are lifted from the desktop app's public/theme-quantum.css
    variables so both clients share one visual identity:

        - -bg           #050508   app background
        - -panel        #0b0b12   card / surface fill
        - -text         #e0e0e6   primary text
        - -muted        50% white secondary text
        - -accent       #6c3bff   violet (primary brand accent)
        - -accent-soft  #9b73ff   soft violet (headings / links)
        - -accent-2     #00e5ff   cyan (secondary accent)
        - -btn          #14b8a6   teal (primary CTA buttons)
        - -green        #34d399   success
        - -amber        #fbbf24   warning
        - -red-soft     #ffb3ba   soft error text

    There is NO values-night/ overlay any more: the app ships dark-only
    (decision recorded in the rebrand plan), so this file is the single
    source of truth for every color slot. The legacy colorCommonN slots
    are kept name-stable (≈200 usages across layouts/drawables/Java) and
    simply retuned to the Quantum palette:

        colorCommon1  heading / table-caption text     -> soft violet
        colorCommon2  selected-tab / emphasis text     -> soft violet
        colorCommon3  secondary text, hairline strokes -> light gray-violet
        colorCommon6  primary body text                -> #e0e0e6
        colorCommon7  card / surface fill              -> panel #0b0b12
        colorCommon10 dialog background                -> panel #0b0b12
-->
<resources>

  <!-- Core Quantum palette (new names; prefer these in new code). -->
  <color name="quantumBg">#050508</color>
  <color name="quantumPanel">#0b0b12</color>
  <color name="quantumPanelRaised">#14141d</color>
  <color name="quantumText">#e0e0e6</color>
  <color name="quantumMuted">#9a9aa6</color>
  <color name="quantumBorder">#26262f</color>
  <color name="quantumAccent">#6c3bff</color>
  <color name="quantumAccentSoft">#9b73ff</color>
  <color name="quantumCyan">#00e5ff</color>
  <color name="quantumTeal">#14b8a6</color>
  <color name="quantumGreen">#34d399</color>
  <color name="quantumAmber">#fbbf24</color>
  <color name="quantumRedSoft">#ffb3ba</color>

  <!-- Read only -->
  <color name="colorAccent">#6c3bff</color>
  <color name="colorPrimaryDark">#050508</color>
  <!--
      Banner / button gradient stops: violet -> soft violet -> cyan,
      mirroring the desktop hero gradient (accent -> accent-soft ->
      accent-2). Consumed by button_square_shadow and the top banner.
  -->
  <color name="colorPrimaryDarkStart">#6c3bff</color>
  <color name="colorPrimaryDarkCenter">#7e57f2</color>
  <color name="colorPrimaryDarkEnd">#00b8cc</color>
  <color name="colorWhite">#FFFFFFFF</color>
  <color name="colorBlock">#000000</color>
  <color name="colorGray">#8a8a96</color>

  <!-- Change themes wise -->
  <color name="colorEye">#9b73ff</color>
  <color name="colorToastBackground">#6c3bff</color>

  <color name="colorProgressStart">#9b73ff</color>
  <color name="colorProgressEnd">#00ffffff</color>

  <color name="colorRectangleLine">#e0e0e6</color>

  <!-- Offline overlay scrim (was 50% dark gray in night mode). -->
  <color name="colorGainsboro">#80101018</color>
  <color name="colorRedTwo">#ff7043</color>

  <color name="colorGreenOne">#34d399</color>
  <color name="colorGreen">#34d399</color>

  <!--
      Legacy "light card on banner" fill (button_square_shadow inner
      rectangle, wallet cards). Dark theme: panel surface.
  -->
  <color name="colorMilkWhite">#0b0b12</color>

  <color name="colorCommon1">#9b73ff</color>
  <color name="colorCommon2">#9b73ff</color>

  <color name="colorCommon3">#b9b9c6</color>
  <color name="colorCommon4">#3a3a48</color>
  <color name="colorCommon5">#14141d</color>

  <color name="colorCommon6">#e0e0e6</color>
  <color name="colorCommon7">#0b0b12</color>

  <color name="colorCommon8">#c084fc</color>
  <color name="colorCommon9">#ffb3ba</color>

  <color name="colorCommon10">#0b0b12</color>

  <color name="colorSeedA">#0b0b12</color>

  <!--
      Seed-tile background colors are deliberately kept identical to the
      pre-rebrand values: seed entry/verification is a high-stakes task
      and users identify tiles by color ("the blue tile", "the black
      tile"). Retinting them for the violet theme would break that
      mental model for users migrating between platforms/versions.
  -->
  <color name="colorCommonSeedA">#0000FF</color>
  <color name="colorCommonSeedB">#008000</color>
  <color name="colorCommonSeedC">#AA6F00</color>
  <color name="colorCommonSeedD">#EB2B4D</color>
  <color name="colorCommonSeedE">#5E0D1B</color>
  <color name="colorCommonSeedF">#9B0BB8</color>
  <color name="colorCommonSeedG">#046D94</color>
  <!--
      Tile H is BLACK, which is invisible against the dark app
      background. H stays black for color identity, but
      bg_seed_view_h_curve.xml (and edit variant) get a white border +
      the seed label above renders white via colorCommonSeedHLabel.
  -->
  <color name="colorCommonSeedH">#000000</color>
  <color name="colorCommonSeedI">#3519C5</color>
  <color name="colorCommonSeedJ">#648D24</color>
  <color name="colorCommonSeedK">#DF1313</color>
  <color name="colorCommonSeedL">#003F4D</color>

  <!-- White label + border so the black H tile stays visible on dark. -->
  <color name="colorCommonSeedHLabel">#FFFFFFFF</color>
  <color name="colorCommonSeedHBorder">#FFFFFFFF</color>

  <!--
      Text color for the seed-WORD glyphs displayed inside the colored
      tiles on the New-seed / Reveal-seed screens. The tile fills are
      saturated deep-tones (or pure black for H), so a single white
      glyph gives uniformly high in-tile contrast.
  -->
  <color name="colorSeedViewWord">#FFFFFFFF</color>

  <!--
      Muted secondary text (contract-address line under the Send asset
      spinner, empty-state captions). One step below colorCommon6 /
      colorCommon3 in the hierarchy; maps to the desktop -muted
      (50% white) tone, lightened slightly for small font sizes.
  -->
  <color name="colorMutedSecondaryText">#9a9aa6</color>

</resources>
